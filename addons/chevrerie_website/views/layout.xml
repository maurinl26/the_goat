<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Injection des Google Fonts dans le <head> du site -->
    <template id="chevrerie_fonts" inherit_id="website.layout" name="Chèvrerie Fonts">
        <xpath expr="//head" position="inside">
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="crossorigin"/>
            <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&amp;family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
        </xpath>
    </template>

</odoo>
